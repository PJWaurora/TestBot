# Optional local overrides for the Weather module service.
# Copy to config/modules/weather.env and fill in real values locally.
#
# Do not commit config/modules/weather.env.

WEATHER_GROUP_ALLOWLIST=
WEATHER_GROUP_BLOCKLIST=
WEATHER_COMMAND_PREFIXES=/,.
WEATHER_AMAP_KEY=
WEATHER_AMAP_BASE_URL=https://restapi.amap.com/v3/weather/weatherInfo
WEATHER_TIMEOUT=5
WEATHER_TRUST_ENV_PROXY=false
# WEATHER_CITYCODE_PATH=/app/citycode.xlsx

# When enabled, the Weather module returns rendered weather card images.
RENDERER_ENABLED=false
RENDERER_INTERNAL_BASE_URL=http://renderer-rust:8020
RENDERER_TIMEOUT=3
