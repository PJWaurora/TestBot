# Optional local overrides for the TSPerson module service.
# Copy to config/modules/tsperson.env and fill in real values locally.
#
# Do not commit config/modules/tsperson.env.

TSPERSON_GROUP_ALLOWLIST=
TSPERSON_GROUP_BLOCKLIST=
TS3_HOST=
TS3_QUERY_PORT=13986
TS3_QUERY_USER=
TS3_QUERY_PASSWORD=
TS3_VIRTUAL_SERVER_ID=1
TS3_TIMEOUT=5
TSPERSON_COMMAND_PREFIXES=/,.
