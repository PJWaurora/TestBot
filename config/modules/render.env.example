# Optional local overrides for the Rust renderer service.
# Copy to config/modules/render.env and fill in real values locally.
#
# Do not commit config/modules/render.env.

# RENDERER_PUBLIC_BASE_URL is read from the root .env by docker-compose.render.yml
# because modules and NapCat also need the same externally reachable URL.
RENDERER_ASSET_DIR=/data/assets
RUST_LOG=info
