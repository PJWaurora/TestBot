# Optional local overrides for the Pixiv module service.
# Copy to config/modules/pixiv.env and fill in real values locally.
#
# Do not commit config/modules/pixiv.env.

PIXIV_REFRESH_TOKEN=
PIXIV_TIMEOUT=8
PIXIV_TRUST_ENV_PROXY=true
PIXIV_HTTP_PROXY=
PIXIV_COMMAND_PREFIXES=/,.
PIXIV_GROUP_ALLOWLIST=
PIXIV_GROUP_BLOCKLIST=
PIXIV_RESTRICTED_TAGS=R-18,R-18G
PIXIV_CACHE_TTL_MINUTES=60
PIXIV_IMAGE_CACHE_DIR=/tmp/testbot-pixiv-assets
PIXIV_IMAGE_CACHE_TTL_SECONDS=3600
PIXIV_ASSET_BASE_URL=http://host.docker.internal:8014
