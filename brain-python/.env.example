# Copy this file to .env for local configuration.
# Do not commit real secrets.
APP_ENV=development
DATABASE_URL=postgres://testbot:replace-with-a-local-password@localhost:5432/testbot?sslmode=disable
OUTBOX_TOKEN=replace-with-a-random-outbox-token

# Message persistence uses DATABASE_URL. When configured, Brain stores
# normalized incoming messages and bot responses in Postgres.

# Memory runtime. Long-term memory recall is enabled by default when
# DATABASE_URL and the memory migration are available.
MEMORY_ENABLED=true
MEMORY_ADMIN_USER_IDS=

# Command signatures accepted by deterministic modules and the fake planner.
# Comma, semicolon, or whitespace separated prefixes are accepted.
BRAIN_COMMAND_PREFIXES=/,.

# Optional extra or overriding remote deterministic modules. Comma separated
# name=url entries. Brain merges these with BRAIN_MODULE_SERVICE_DEFAULTS from
# the compose overlay so stale local values do not hide newly added modules.
BRAIN_MODULE_SERVICES=
BRAIN_MODULE_TIMEOUT=20

# Optional module group policies. Empty means all groups are allowed.
# Comma, semicolon, or whitespace separated group IDs are accepted.
BRAIN_GROUP_ALLOWLIST=
BRAIN_GROUP_BLOCKLIST=
BRAIN_MODULE_BILIBILI_GROUP_ALLOWLIST=
BRAIN_MODULE_BILIBILI_GROUP_BLOCKLIST=
BRAIN_MODULE_TSPERSON_GROUP_ALLOWLIST=
BRAIN_MODULE_TSPERSON_GROUP_BLOCKLIST=
BRAIN_MODULE_WEATHER_GROUP_ALLOWLIST=
BRAIN_MODULE_WEATHER_GROUP_BLOCKLIST=
BRAIN_MODULE_PIXIV_GROUP_ALLOWLIST=
BRAIN_MODULE_PIXIV_GROUP_BLOCKLIST=
BILIBILI_GROUP_ALLOWLIST=
BILIBILI_GROUP_BLOCKLIST=
TSPERSON_GROUP_ALLOWLIST=
TSPERSON_GROUP_BLOCKLIST=
WEATHER_GROUP_ALLOWLIST=
WEATHER_GROUP_BLOCKLIST=
PIXIV_GROUP_ALLOWLIST=
PIXIV_GROUP_BLOCKLIST=
PIXIV_COMMAND_PREFIXES=/,.
