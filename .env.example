APP_ENV=local

POSTGRES_DB=testbot
POSTGRES_USER=testbot
POSTGRES_PASSWORD=replace-with-a-local-password
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_IMAGE=pgvector/pgvector:pg16
DATABASE_URL=postgres://testbot:replace-with-a-local-password@postgres:5432/testbot?sslmode=disable

BRAIN_BASE_URL=http://brain-python:8000
PYTHON_BRAIN_URL=http://brain-python:8000
BRAIN_PORT=8000
BRAIN_IMAGE=testbot-brain-python:latest

GATEWAY_LISTEN_ADDR=:808
GATEWAY_WS_PATH=/ws
GATEWAY_PORT=808
GATEWAY_IMAGE=testbot-gateway-go:latest

# Brain runtime settings such as remote modules and group policies live in brain-python/.env.

# Optional module service compose overlay settings. These are used only with:
# docker compose -f docker-compose.yml -f docker-compose.modules.yml up
BILIBILI_MODULE_CONTEXT=../testbot-module-bilibili
TSPERSON_MODULE_CONTEXT=../testbot-module-tsperson
BILIBILI_MODULE_IMAGE=testbot-module-bilibili:latest
TSPERSON_MODULE_IMAGE=testbot-module-tsperson:latest
BILIBILI_MODULE_PORT=8011
TSPERSON_MODULE_PORT=8012
BRAIN_MODULE_SERVICES=bilibili=http://module-bilibili:8011,tsperson=http://module-tsperson:8012
BRAIN_MODULE_TIMEOUT=5

# Optional Rust renderer compose overlay settings. These are used with:
# docker compose -f docker-compose.yml -f docker-compose.modules.yml -f docker-compose.render.yml up
RENDER_SERVICE_CONTEXT=../testbot-render-service
RENDER_SERVICE_IMAGE=testbot-renderer-rust:latest
RENDER_SERVICE_PORT=8020
RENDERER_PUBLIC_BASE_URL=http://renderer-rust:8020

# Module-side rendering is configured per module in config/modules/*.env.
# For example, set RENDERER_ENABLED=true in config/modules/tsperson.env.

# Pin the image tag for real deployments instead of using latest.
NAPCAT_IMAGE=mlikiowa/napcat-docker:latest
NAPCAT_DATA_DIR=./napcat
NAPCAT_BIND_HOST=127.0.0.1
NAPCAT_WEBUI_PORT=6099
NAPCAT_HTTP_PORT=3000
NAPCAT_WS_PORT=3001
NAPCAT_UID=1000
NAPCAT_GID=1000
TZ=Asia/Shanghai

# Optional Docker build proxy for dependency downloads during image builds.
# Set DOCKER_BUILD_NETWORK=host only if build steps must reach a host-local proxy.
DOCKER_BUILD_NETWORK=default
DOCKER_BUILD_HTTP_PROXY=
DOCKER_BUILD_HTTPS_PROXY=
DOCKER_BUILD_NO_PROXY=localhost,127.0.0.1,::1,postgres,brain-python,gateway-go
